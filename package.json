// ═══════════════════════════════════════════════════════════
// REPERIBILITÀ — localStorage
// ═══════════════════════════════════════════════════════════
async function getRepStore(){
  return (_read(K_REP, [])||[]).map(rp=>{
    const r=RESOURCES.find(x=>x.id===rp.risorsaId);
    return r?{ id:rp.id, fullName:r.fullName, progetto:rp.progetto, teamLead:rp.teamLead||'', anno:rp.anno, mese:rp.mese, giorni:Array.isArray(rp.giorni)?rp.giorni:[] }:null;
  }).filter(Boolean);
}
async function repForUser(fullName){
  const all=await getRepStore(); return all.filter(r=>r.fullName===fullName);
}
async function repForTeam(lead){
  const team=isAdmin?RESOURCES.map(r=>r.fullName):getLeadTeam();
  const all=await getRepStore(); return all.filter(r=>team.includes(r.fullName));
}

// ── state griglia ────────────────────────────────────────
let _repSelectedDays = new Set();

async function initRepPanel(){
  const now = new Date();
  if(isTeamLead||isAdmin){
    document.getElementById('repUserView').style.display='none';
    document.getElementById('repLeadView').style.display='block';
    const mOpts=MONTHS.map((m,i)=>({v:i,l:m}));
    const yOpts=[-1,0,1].map(d=>{const y=now.getFullYear()+d;return{v:y,l:y};});
    popSel('repMonth',mOpts,now.getMonth());
    popSel('repYear',yOpts,now.getFullYear());
    // risorsa: solo il team del lead (o tutti se admin)
    const team=isAdmin?RESOURCES:RESOURCES.filter(r=>getLeadTeam().includes(r.fullName));
    const rSel=document.getElementById('repRisorsa');
    rSel.innerHTML='<option value="">— Seleziona —</option>';
    team.forEach(r=>{const o=document.createElement('option');o.value=r.fullName;o.textContent=r.fullName;rSel.appendChild(o);});
    // filtri lista
    const rFilt=document.getElementById('repFilterRisorsa');
    rFilt.innerHTML='<option value="">Tutte le risorse</option>';
    team.forEach(r=>{const o=document.createElement('option');o.value=r.fullName;o.textContent=r.fullName;rFilt.appendChild(o);});
    const yFilt=document.getElementById('repFilterAnno');
    yFilt.innerHTML='<option value="">Tutti gli anni</option>';
    yOpts.forEach(({v,l})=>{const o=document.createElement('option');o.value=v;o.textContent=l;yFilt.appendChild(o);});
    const mFilt=document.getElementById('repFilterMese');
    mFilt.innerHTML='<option value="">Tutti i mesi</option>';
    mOpts.forEach(({v,l})=>{const o=document.createElement('option');o.value=v;o.textContent=l;mFilt.appendChild(o);});
    // Popola select progetto: solo i progetti del lead corrente (o tutti se admin)
    const meRes=RESOURCES.find(r=>r.fullName===currentUser);
    const myPrjs=isAdmin?await getProjects():(meRes?.progetti||[meRes?.progetto]).filter(Boolean).sort();
    const repPrjSel=document.getElementById('repProgetto');
    repPrjSel.innerHTML='<option value="">— Seleziona —</option>';
    myPrjs.forEach(p=>{const o=document.createElement('option');o.value=p;o.textContent=p;repPrjSel.appendChild(o);});
    await buildRepGriglia();
    await renderRepTeam();
  } else {
    document.getElementById('repUserView').style.display='block';
    document.getElementById('repLeadView').style.display='none';
    await renderRepMine();
  }
}

// Restituisce Set di giorni (1-31) in cui la risorsa è in ferie nel mese/anno dato
async function ferieGiorniSet(fullName, year, month){
  const r=RESOURCES.find(x=>x.fullName===fullName);
  const mine=r?(_read(K_FER, [])||[]).filter(f=>f.risorsaId===r.id):[];
  const set = new Set();
  mine.forEach(e=>{
    let cur=new Date(e.start+'T12:00:00'), en=new Date(e.end+'T12:00:00');
    while(cur<=en){
      if(cur.getFullYear()===year && cur.getMonth()===month) set.add(cur.getDate());
      cur.setDate(cur.getDate()+1);
    }
  });
  return set;
}

async function buildRepGriglia(){
  const month=+document.getElementById('repMonth').value;
  const year=+document.getElementById('repYear').value;
  const risorsa=document.getElementById('repRisorsa').value;
  const dim=new Date(year,month+1,0).getDate();
  const hol=getHol(year);
  const ferie=risorsa ? await ferieGiorniSet(risorsa,year,month) : new Set();
  _repSelectedDays=new Set();
  document.getElementById('repGrigliaWrap').style.display='block';
  const DN=['D','L','M','M','G','V','S'];
  // intestazione
  let h='<table><thead><tr>';
  for(let d=1;d<=dim;d++){
    const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt);
    const ih=hol.has(ds),iw=wd===0||wd===6;
    const col=ih?'#ede9f9':iw?'#f0edf8':'#1d7fc4';
    const tc=ih?'#7c5cbf':iw?'#aaa':'#fff';
    h+=`<th style="background:${col};color:${tc};padding:3px 2px;min-width:26px;text-align:center;font-size:.68rem"><div>${DN[wd]}</div><div style="font-size:.72rem">${d}</div></th>`;
  }
  h+='</tr></thead><tbody><tr>';
  // celle
  for(let d=1;d<=dim;d++){
    const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt);
    const ih=hol.has(ds),iw=wd===0||wd===6;
    const isFerie=ferie.has(d);
    if(isFerie){
      // giorno in ferie: sfondo arancio, lettera F, non cliccabile
      h+=`<td style="background:#fff3cd;border:1px solid #ffc107;padding:3px 2px;text-align:center" title="In ferie">
        <div style="width:18px;height:18px;border-radius:4px;background:#ffc107;color:#856404;font-size:.68rem;font-weight:700;line-height:18px;text-align:center;margin:0 auto;cursor:not-allowed">F</div>
      </td>`;
    } else {
      const bg=ih?'#ede9f9':iw?'#f0edf8':'#e8f0f8';
      h+=`<td style="background:${bg};border:1px solid #dde8f0;padding:5px 2px;text-align:center">
        <div class="rep-day${ih?' festivo':''}" id="rd_${d}" onclick="toggleRepDay(${d})"></div>
      </td>`;
    }
  }
  h+='</tr></tbody></table>';
  document.getElementById('repGriglia').innerHTML=h;
}

function toggleRepDay(d){
  const el=document.getElementById('rd_'+d); if(!el)return;
  if(_repSelectedDays.has(d)){_repSelectedDays.delete(d);el.classList.remove('on');}
  else{_repSelectedDays.add(d);el.classList.add('on');}
}

async function applyRepRange(){
  const start=document.getElementById('repRangeStart').value;
  const end=document.getElementById('repRangeEnd').value;
  const month=+document.getElementById('repMonth').value;
  const year=+document.getElementById('repYear').value;
  const risorsa=document.getElementById('repRisorsa').value;
  if(!start||!end){showMsg('repMsg','Inserisci date inizio e fine.','err');return;}
  if(end<start){showMsg('repMsg','Data fine deve essere ≥ inizio.','err');return;}
  const ferie=risorsa?await ferieGiorniSet(risorsa,year,month):new Set();
  let cur=new Date(start+'T12:00:00'),en=new Date(end+'T12:00:00');
  while(cur<=en){
    if(cur.getFullYear()===year&&cur.getMonth()===month){
      const d=cur.getDate();
      if(!ferie.has(d)){ // non selezionare giorni di ferie
        _repSelectedDays.add(d);
        const el=document.getElementById('rd_'+d);
        if(el) el.classList.add('on');
      }
    }
    cur.setDate(cur.getDate()+1);
  }
}

function clearRepGriglia(){
  _repSelectedDays=new Set();
  document.querySelectorAll('.rep-day.on').forEach(el=>el.classList.remove('on'));
}

async function saveReperibilita(){
  const progetto=document.getElementById('repProgetto').value;
  const risorsa=document.getElementById('repRisorsa').value;
  const month=+document.getElementById('repMonth').value;
  const year=+document.getElementById('repYear').value;
  if(!progetto){showMsg('repMsg','Inserisci il nome del progetto.','err');return;}
  if(!risorsa){showMsg('repMsg','Seleziona una risorsa.','err');return;}
  if(_repSelectedDays.size===0){showMsg('repMsg','Seleziona almeno un giorno.','err');return;}
  const giorni=[..._repSelectedDays].sort((a,b)=>a-b);
  const rRes=RESOURCES.find(x=>x.fullName===risorsa);
  if(!rRes?.id){showMsg('repMsg','Risorsa non trovata.','err');return;}
  const tlName = (currentUser && currentUser!=='ADMIN') ? currentUser : null;
  showSpinner();
  try {
    await call('saveRep', { risorsaId:rRes.id, progetto, teamLead:tlName, anno:year, mese:month, giorni });
    await reloadAll();
  } catch(e){ hideSpinner(); showMsg('repMsg','Errore: '+e.message,'err'); return; }
  hideSpinner();
  showMsg('repMsg',`Reperibilità salvata per ${risorsa} ✓`,'ok');
  clearRepGriglia();
  await renderRepTeam();
}

async function renderRepTeam(){
  const fRis=document.getElementById('repFilterRisorsa')?.value||'';
  const fAnno=document.getElementById('repFilterAnno')?.value||'';
  const fMese=document.getElementById('repFilterMese')?.value;
  const teamNames=isAdmin?RESOURCES.map(r=>r.fullName):getLeadTeam();
  let filtered=(await getRepStore()).filter(r=>{
    if(!isAdmin&&!teamNames.includes(r.fullName))return false;
    if(fRis&&r.fullName!==fRis)return false;
    if(fAnno&&+r.anno!==+fAnno)return false;
    if(fMese!==''&&fMese!==undefined&&+r.mese!==+fMese)return false;
    return true;
  });
  const el=document.getElementById('repTeamList');
  if(!filtered.length){el.innerHTML='<p style="color:#888;font-size:.84rem">Nessuna reperibilità trovata.</p>';return;}
  const ferieMap={};
  await Promise.all(filtered.map(async r=>{
    ferieMap[r.fullName+'|'+r.anno+'|'+r.mese]=await ferieGiorniSet(r.fullName,r.anno,r.mese);
  }));
  el.innerHTML=filtered.map(r=>{
    const ferie=ferieMap[r.fullName+'|'+r.anno+'|'+r.mese]||new Set();
    const daysStr=r.giorni.map(d=>{
      const iF=ferie.has(d);
      return `<span style="display:inline-block;background:${iF?'#ffc107':'#1d7fc4'};color:${iF?'#856404':'#fff'};border-radius:4px;padding:1px 5px;margin:1px;font-size:.72rem">${iF?'⚠️ ':''}${d} ${MONTHS[r.mese].slice(0,3)}</span>`;
    }).join('');
    const canDel=isAdmin||(isTeamLead&&getLeadTeam().includes(r.fullName));
    return `<div class="rep-entry">
      <div style="flex:1">
        <div class="re-prog">📁 ${r.progetto}</div>
        <div class="re-meta"><b>${r.fullName}</b> · ${MONTHS[r.mese]} ${r.anno} · ${r.giorni.length} giorn${r.giorni.length===1?'o':'i'} · <span style="color:#888">Lead: ${r.teamLead||'—'}</span></div>
        <div class="re-days">${daysStr}</div>
      </div>
      ${canDel?`<button class="btn-del" onclick="deleteRep(${r.id},'${r.fullName.replace(/'/g,"\'")}','${r.progetto.replace(/'/g,"\'")}')">🗑</button>`:''}
    </div>`;
  }).join('');
}

// Vista utente: sola lettura, solo le proprie, con indicazione ferie
async function renderRepMine(){
  const mine=await repForUser(currentUser);
  const el=document.getElementById('repMyList');
  if(!mine.length){el.innerHTML='<p style="color:#888;font-size:.84rem">Nessuna reperibilità assegnata.</p>';return;}
  const ferieMineMap={};
  await Promise.all(mine.map(async r=>{
    ferieMineMap[r.anno+'|'+r.mese]=await ferieGiorniSet(currentUser,r.anno,r.mese);
  }));
  el.innerHTML=mine.map(r=>{
    const ferie=ferieMineMap[r.anno+'|'+r.mese]||new Set();
    const daysStr=r.giorni.map(d=>{
      const iF=ferie.has(d);
      return `<span style="display:inline-block;background:${iF?'#ffc107':'#1d7fc4'};color:${iF?'#856404':'#fff'};border-radius:4px;padding:1px 5px;margin:1px;font-size:.72rem" title="${iF?'Giorno di ferie!':''}">${iF?'⚠️ ':''}${d} ${MONTHS[r.mese].slice(0,3)}</span>`;
    }).join('');
    const conflitti=r.giorni.filter(d=>ferie.has(d)).length;
    return `<div class="rep-entry">
      <div>
        <div class="re-prog">📁 ${r.progetto}</div>
        <div class="re-meta">${MONTHS[r.mese]} ${r.anno} · ${r.giorni.length} giorn${r.giorni.length===1?'o':'i'}${conflitti?` · <span style="color:#856404;font-weight:700">⚠️ ${conflitti} giorn${conflitti===1?'o':'i'} in ferie!</span>`:''}</div>
        <div class="re-days">${daysStr}</div>
      </div>
    </div>`;
  }).join('');
}

async function deleteRep(id,name,prog){
  openModal('Elimina reperibilità',`Eliminare la reperibilità di "${name}" per il progetto "${prog}"?`,async ()=>{
    showSpinner();
    try { await call('deleteRep', { id }); await reloadAll(); }
    catch(e){ hideSpinner(); showMsg('repMsg','Errore: '+e.message,'err'); return; }
    hideSpinner();
    await renderRepTeam();
    showMsg('repMsg','Reperibilità eliminata.','ok');
  },'Elimina');
}

