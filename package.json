const TABS=['ore','riepilogo','trend','ferie','overview','reperibilita','admin'];
async function showTab(t){
  document.querySelectorAll('.tab').forEach((el,i)=>el.classList.toggle('active',TABS[i]===t));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+t).classList.add('active');
  if(t==='trend') renderTrend().catch(console.error);
  if(t==='overview') renderOverview();
  if(t==='riepilogo') loadRiepilogo().catch(console.error);
  if(t==='reperibilita') initRepPanel();  // initRepPanel è già async
  if(t==='ferie'&&!isAdmin){ initFerieRisorseCard(); await renderFerieList(); }
}

