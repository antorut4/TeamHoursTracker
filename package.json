async function deleteResource(idx,name){
  openModal('Elimina risorsa',`Eliminare "${name}"? Verranno rimosse anche le ore, le ferie e la reperibilità associate.`,async ()=>{
    const rid=RESOURCES[idx].id;
    showSpinner();
    try {
      await call('deleteResource', { id:rid });   // ON DELETE CASCADE lato DB pulisce allocazioni/ore/ferie/reperibilità/password
      await reloadAll();
