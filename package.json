// OVERVIEW (tutti)
// ═══════════════════════════════════════════════════════════
async function renderOverview(){
  const month=+document.getElementById('ovMonth').value, year=+document.getElementById('ovYear').value;
  const lf=document.getElementById('ovLead').value, members=getMembers(lf);
  const dim=new Date(year,month+1,0).getDate(), hol=getHol(year);
  let allFer=[];
  allFer=(_read(K_FER, [])||[]).map(f=>{ const r=RESOURCES.find(x=>x.id===f.risorsaId); return r?{user:r.fullName,start:f.start,end:f.end,tipo:f.tipo}:null; }).filter(Boolean);
  const DN=['D','L','M','M','G','V','S'];
  const md={}; members.forEach(m=>{md[m]={};});
  allFer.forEach(e=>{ if(!md[e.user])return; let c=new Date(e.start+'T12:00:00'),en=new Date(e.end+'T12:00:00'); while(c<=en){ const ds=localDate(c); if(ds.startsWith(`${year}-${String(month+1).padStart(2,'0')}`))md[e.user][ds]=e.tipo; c.setDate(c.getDate()+1); } });
  if(!members.length){document.getElementById('ovCalendar').innerHTML='<p style="color:#aaa;font-size:.84rem">Nessuna risorsa.</p>';document.getElementById('ovCards').innerHTML='';document.getElementById('ovOverlaps').innerHTML='';return;}
  let h=`<table style="border-collapse:collapse;font-size:.74rem;width:100%"><thead><tr><th style="padding:5px 9px;background:#5B36A9;color:#fff;text-align:left;white-space:nowrap;min-width:90px">Risorsa</th>`;
  for(let d=1;d<=dim;d++){
    const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt);
    const ih=hol.has(ds),iw=wd===0||wd===6;
    h+=`<th style="padding:2px 1px;background:${ih?'#e8e4f4':iw?'#f0edf8':'#5B36A9'};color:${ih?'#7c5cbf':iw?'#ccc':'#fff'};text-align:center;min-width:22px;font-weight:${ih||iw?400:700}"><div style="font-size:.6rem">${DN[wd]}</div><div>${d}</div></th>`;
  }
  h+=`<th style="padding:5px 6px;background:#5B36A9;color:#fff;text-align:center;min-width:32px">Tot.</th></tr></thead><tbody>`;
  const sumData=[];
  members.forEach((m,mi)=>{
    h+=`<tr style="background:${mi%2?'#faf9fd':'#fff'}"><td style="padding:5px 9px;font-weight:700;font-size:.77rem;color:#5B36A9;border-right:2px solid #ede9f9;white-space:nowrap">${m.split(' ')[0]}<br><span style="font-weight:400;color:#ccc;font-size:.67rem">${m.split(' ').slice(1).join(' ')}</span></td>`;
    let tot=0; const bt={};
    for(let d=1;d<=dim;d++){
      const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt);
      const ih=hol.has(ds),iw=wd===0||wd===6,tipo=md[m][ds];
      let cb='',dot='';
      if(tipo){const c=TIPO_C(tipo);cb=`background:${c}22`;dot=`<div style="width:8px;height:8px;border-radius:2px;background:${c};margin:0 auto" title="${tipo}"></div>`;if(!iw&&!ih){tot++;bt[tipo]=(bt[tipo]||0)+1;}}
      else if(ih)cb='background:#e8e4f4'; else if(iw)cb='background:#f0edf8';
      h+=`<td style="padding:3px 1px;text-align:center;${cb}">${dot}</td>`;
    }
    h+=`<td style="padding:5px 6px;text-align:center;font-weight:700;color:#5B36A9;border-left:2px solid #ede9f9">${tot}</td></tr>`;
    sumData.push({name:m,days:tot,bt});
  });
  document.getElementById('ovCalendar').innerHTML=h+'</tbody></table>';
  document.getElementById('ovCards').innerHTML=sumData.map((s,i)=>{
    const det=Object.entries(s.bt).map(([t,n])=>`${t}: ${n}gg`).join(' · ')||'Nessuna assenza';
    return `<div class="ov-card"><div class="on" style="color:${colorFor(s.name)}">${s.name}</div><div class="od">${s.days} <span style="font-size:.78rem;font-weight:400;color:#aaa">gg</span></div><div class="oi">${det}</div></div>`;
  }).join('');
  const ovs=[];
  for(let d=1;d<=dim;d++){
    const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt);
    if(wd===0||wd===6||hol.has(ds))continue;
    const ab=members.filter(m=>md[m][ds]);
    if(ab.length>1)ovs.push({ds,names:ab,tipi:ab.map(m=>md[m][ds])});
  }
  document.getElementById('ovOverlaps').innerHTML=ovs.length
    ?`<div style="background:#fff3cd;border:1px solid #ffc107;border-radius:8px;padding:11px 13px"><div style="font-weight:700;color:#856404;margin-bottom:7px">⚠️ Sovrapposizioni (${ovs.length} giorni)</div>${ovs.map(o=>`<div style="font-size:.8rem;color:#856404;margin-bottom:3px">${fmt(o.ds)} — ${o.names.map((n,i)=>`${n.split(' ')[0]} (${o.tipi[i]})`).join(', ')}</div>`).join('')}</div>`
    :`<div style="background:#d4edda;border-radius:8px;padding:8px 12px;font-size:.83rem;color:#155724">✓ Nessuna sovrapposizione questo mese</div>`;
}

