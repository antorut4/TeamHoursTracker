<script>
// ══════════════════════════════════════════════════════════════
// DATA LAYER — 100% client-side (localStorage). Nessun backend,
// nessuna credenziale: i dati vivono nel browser di chi usa l'app.
// La condivisione tra postazioni avviene via Backup/Ripristina (JSON).
// ══════════════════════════════════════════════════════════════

// ── overlay di rete minimale ──
let _busy=0;
function showSpinner(){ _busy++; const e=document.getElementById('netSpinner'); if(e) e.style.display='flex'; }
function hideSpinner(){ _busy=Math.max(0,_busy-1); if(_busy===0){ const e=document.getElementById('netSpinner'); if(e) e.style.display='none'; } }

// Endpoint del proxy serverless (Netlify Function). Nessuna credenziale nel client.
const FN_URL = '/api/db';

// chiamata al proxy: { action, payload } -> { ok, data } | { error }
async function call(action, payload){
  const res = await fetch(FN_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action, payload: payload || {} })
  });
  let j=null;
  try { j = await res.json(); } catch {}
  if(!res.ok || !j || j.error){ throw new Error((j && j.error) ? j.error : ('Errore di rete ' + res.status)); }
  return j.data;
}

// ── chiavi logiche per la cache (le letture _read() leggono da qui) ──
const K_HRS='hrs', K_FER='fer', K_RES='res', K_REP='rep', K_PRJ='prj';
const K_FRIS = 'hrs_fris';   // preferenze monitoraggio ferie: PER-UTENTE, resta in localStorage
const DEFAULT_APWD = 'admin2024';

// ── cache in memoria (shape identico alla precedente versione localStorage) ──
let _cache = { res:[], prj:[], hrs:[], fer:[], rep:[] };
let _prjIdByName={}, _prjNameById={};
// _read(key) legge dalla CACHE (sincrono): tutte le funzioni di lettura restano invariate
function _read(key, fallback){
  switch(key){
    case K_RES: return _cache.res;
    case K_PRJ: return _cache.prj;
    case K_HRS: return _cache.hrs;
    case K_FER: return _cache.fer;
    case K_REP: return _cache.rep;
    default: return fallback;
  }
}
function _write(){ /* i dati vivono su DB: le mutazioni passano dalle funzioni save/add/delete */ }
function _nextId(arr){ return (arr||[]).reduce((m,x)=>Math.max(m, x.id||0), 0) + 1; } // legacy

// ── un'unica bootstrap ricostruisce tutta la cache dallo stato del DB ──
async function reloadAll(){
  const d = await call('bootstrap');
  // progetti + mappe nome<->id
  _cache.prj = (d.progetti||[]).map(r=>r.nome);
  _prjIdByName={}; _prjNameById={};
  (d.progetti||[]).forEach(r=>{ _prjIdByName[r.nome]=r.id; _prjNameById[r.id]=r.nome; });
  // risorse + allocazioni -> progetti:[nomi]
  const byRes={};
  (d.allocazioni||[]).forEach(a=>{ if(!byRes[a.risorsa_id]) byRes[a.risorsa_id]=[]; byRes[a.risorsa_id].push(_prjNameById[a.progetto_id]); });
  RESOURCES = (d.risorse||[]).map(r=>({
    id:r.id, nome:r.nome, cognome:r.cognome, fullName:r.full_name,
    teamLead:r.team_lead||'', progetti:(byRes[r.id]||[]).filter(Boolean)
  }));
  _cache.res = RESOURCES;
  // ore
  _cache.hrs = (d.ore||[]).map(o=>({ id:o.id, risorsaId:o.risorsa_id, anno:o.anno, mese:o.mese,
    ore_q1:o.ore_q1, note_q1:o.note_q1, ore_q2:o.ore_q2, note_q2:o.note_q2 }));
  // ferie
  _cache.fer = (d.ferie||[]).map(f=>({ id:f.id, risorsaId:f.risorsa_id, start:f.data_inizio, end:f.data_fine, tipo:f.tipo, note:f.note }));
  // reperibilità (mappa progetto_id->nome e team_lead_id->fullName)
  _cache.rep = (d.rep||[]).map(rp=>{
    const tl = rp.team_lead_id!=null ? RESOURCES.find(x=>x.id===rp.team_lead_id) : null;
    return { id:rp.id, risorsaId:rp.risorsa_id, progetto:_prjNameById[rp.progetto_id]||'',
      teamLead: tl?tl.fullName:'', anno:rp.anno, mese:rp.mese, giorni: Array.isArray(rp.giorni)?rp.giorni:[] };
  });
}
// reload per-dominio: con il proxy ricarichiamo tutto (volumi piccoli, stato sempre coerente)
async function reloadProjects(){ return reloadAll(); }
async function reloadResources(){ return reloadAll(); }
async function reloadHrs(){ return reloadAll(); }
async function reloadFer(){ return reloadAll(); }
async function reloadRep(){ return reloadAll(); }

let _projectsCache=null;
async function getProjects(){ return _cache.prj.slice(); }
async function saveProjects(){ _projectsCache=null; } // gestito da addProject/deleteProject

const MONTHS = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno',
                'Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
const TIPO_C = t => t==='Ferie'?'#5B36A9':t==='Malattia'?'#e76f51':'#2a9d5c';
const PAL    = ['#5B36A9','#2a9d5c','#e76f51','#1d7fc4','#c9a227','#8e44ad',
                '#16a085','#d35400','#2980b9','#27ae60','#e74c3c','#f39c12',
                '#7f8c8d','#c0392b','#2ecc71'];

// ── storage helpers ──────────────────────────────────────
// S rimane solo per K_FRIS (preferenze ferie locali per utente)
const S = {
  get: k => { try{ const v=localStorage.getItem(k); return v?JSON.parse(v):null }catch{return null} },
  set: (k,v) => { try{ localStorage.setItem(k,JSON.stringify(v)) }catch{} }
};

// ── state ────────────────────────────────────────────────
let currentUser = null;   // fullName o 'ADMIN'
let isAdmin     = false;
let isTeamLead  = false;
let RESOURCES   = [];


// ═══════════════════════════════════════════════════════════
// PASSWORD UTILS (semplice hash deterministico, non crittografico)
// ═══════════════════════════════════════════════════════════
function simpleHash(str){
  let h=5381;
  for(let i=0;i<str.length;i++) h=((h<<5)+h)+str.charCodeAt(i);
  return (h>>>0).toString(36);
}
function _resByName(name){ return RESOURCES.find(x=>x.fullName===name); }
// Le password vivono nel DB e NON sono leggibili dall'endpoint: verifica/imposta via RPC.
async function loadPwdCache(){ /* nessuna cache hash lato client */ }
async function userHasPwd(name){ const r=_resByName(name); if(!r) return false; return !!(await call('userHasPwd',{risorsaId:r.id})); }
async function checkUserPwd(name,pwd){ const r=_resByName(name); if(!r) return false; return !!(await call('checkUserPwd',{risorsaId:r.id, hash:simpleHash(pwd)})); }
async function setUserPwd(name,pwd){ const r=_resByName(name); if(!r) return; await call('setUserPwd',{risorsaId:r.id, hash:simpleHash(pwd)}); }
async function resetUserPwd(name){ const r=_resByName(name); if(!r) return; await call('resetUserPwd',{risorsaId:r.id}); }

// ═══════════════════════════════════════════════════════════
// RISORSE
// ═══════════════════════════════════════════════════════════
async function loadResources(){ await reloadResources(); }
function getMembers(lead){ return lead?RESOURCES.filter(r=>r.teamLead===lead).map(r=>r.fullName):RESOURCES.map(r=>r.fullName); }
function getLeadTeam(){
  // Risorse visibili al team lead: chi ha teamLead=lui OPPURE condivide almeno un progetto con lui
  const me=RESOURCES.find(r=>r.fullName===currentUser);
  const myProjects=new Set((me?.progetti||[me?.progetto]).filter(Boolean));
  return RESOURCES.filter(r=>{
    if(r.fullName===currentUser) return false; // escludi se stesso
    if(r.teamLead===currentUser) return true;
    // condivide almeno un progetto
    const rProjects=(r.progetti||[r.progetto]).filter(Boolean);
    return rProjects.some(p=>myProjects.has(p));
  }).map(r=>r.fullName);
}
function getLeads(){ return [...new Set(RESOURCES.map(r=>r.teamLead).filter(Boolean))].sort(); }
function colorFor(name){ const i=RESOURCES.findIndex(r=>r.fullName===name); return PAL[i%PAL.length]||'#5B36A9'; }

// ═══════════════════════════════════════════════════════════
// FESTIVITÀ + ORE
// ═══════════════════════════════════════════════════════════
const HC={};

// Calcolo Pasqua: algoritmo di Meeus/Jones/Butcher
// Logica: equinozio ecclesiastico = 21 marzo
// -> prima luna piena ecclesiastica >= 21 marzo
// -> prima domenica successiva = Pasqua
function easterSunday(year){
  const a=year%19,
        b=Math.floor(year/100), c=year%100,
        d=Math.floor(b/4),      e=b%4,
        f=Math.floor((b+8)/25),
        g=Math.floor((b-f+1)/3),
        h=(19*a+b-d-g+15)%30,
        i=Math.floor(c/4),      k=c%4,
        l=(32+2*e+2*i-h-k)%7,
        m=Math.floor((a+11*h+22*l)/451),
        month=Math.floor((h+l-7*m+114)/31)-1,
        day  =((h+l-7*m+114)%31)+1;
  return new Date(year, month, day);
}

function getHol(year){
  if(HC[year]) return HC[year];
  // Usa data locale (non UTC) per evitare sfasamenti di fuso orario
  const fd=d=>{
    const y=d.getFullYear(), m=String(d.getMonth()+1).padStart(2,'0'), dd=String(d.getDate()).padStart(2,'0');
    return y+'-'+m+'-'+dd;
  };
  const pa=easterSunday(year);                             // Pasqua (domenica)
  const pk=new Date(year,pa.getMonth(),pa.getDate()+1);   // Pasquetta (lunedi)
  HC[year]=new Set([
    `${year}-01-01`,  // Capodanno
    `${year}-01-06`,  // Epifania
    fd(pa),           // Pasqua
    fd(pk),           // Pasquetta
    `${year}-04-25`,  // Festa della Liberazione
    `${year}-05-01`,  // Festa del Lavoro
    `${year}-06-02`,  // Festa della Repubblica
    `${year}-08-15`,  // Assunzione di Maria (Ferragosto)
    `${year}-11-01`,  // Tutti i Santi
    `${year}-12-08`,  // Immacolata Concezione
    `${year}-12-25`,  // Natale
    `${year}-12-26`,  // Santo Stefano
  ]);
  return HC[year];
}
function localDate(dt){
  const y=dt.getFullYear(),m=String(dt.getMonth()+1).padStart(2,'0'),d=String(dt.getDate()).padStart(2,'0');
  return y+'-'+m+'-'+d;
}
function wHours(year,month,q){
  const h=getHol(year); let days=0;
  const s=q===1?1:16,e=q===1?15:new Date(year,month+1,0).getDate();
  for(let d=s;d<=e;d++){ const dt=new Date(year,month,d),wd=dt.getDay(),ds=localDate(dt); if(wd!==0&&wd!==6&&!h.has(ds))days++; }
  return days*8;
}
function wDays(s,e){
  let c=0,cur=new Date(s+'T12:00:00'),end=new Date(e+'T12:00:00');
  while(cur<=end){ const wd=cur.getDay(),ds=localDate(cur); if(wd!==0&&wd!==6&&!getHol(cur.getFullYear()).has(ds))c++; cur.setDate(cur.getDate()+1); }
  return c;
}

