<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Team Hours Tracker</title>
<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',sans-serif;background:#f5f3fb;color:#1a1a2e;min-height:100vh}

/* ── LOGIN ─────────────────────────────────────────────── */
#loginScreen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,#5B36A9 0%,#7c5cbf 100%);padding:20px}
.login-box{background:#fff;border-radius:16px;padding:36px 32px;width:100%;max-width:360px;box-shadow:0 8px 40px rgba(91,54,169,.25);text-align:center}
.login-box h1{color:#5B36A9;font-size:1.35rem;margin-bottom:4px}
.login-box .subtitle{color:#aaa;font-size:.83rem;margin-bottom:22px}
.login-box select,.login-box input[type=password],.login-box input[type=text]{width:100%;padding:10px 13px;border-radius:8px;font-size:.92rem;border:2px solid #e0daf0;margin-bottom:12px;outline:none;background:#fff;color:#1a1a2e;text-align:left}
.login-box select:focus,.login-box input:focus{border-color:#5B36A9}
.btn-login{width:100%;padding:11px;border-radius:8px;border:none;cursor:pointer;font-weight:700;font-size:.93rem;margin-bottom:6px;transition:.15s}
.btn-login.purple{background:#5B36A9;color:#fff}.btn-login.purple:hover{background:#4a2d8e}
.btn-login.orange{background:#e76f51;color:#fff}.btn-login.orange:hover{background:#c9573b}
.btn-link{background:none;border:none;color:#aaa;font-size:.79rem;cursor:pointer;text-decoration:underline;margin-top:2px}
.btn-link:hover{color:#5B36A9}
.login-err{color:#c0392b;font-size:.81rem;margin:-6px 0 10px;display:none;text-align:left}
.login-info{color:#2a9d5c;font-size:.81rem;margin:-6px 0 10px;display:none;text-align:left}
.first-access-badge{background:#ede9f9;color:#5B36A9;border-radius:7px;padding:8px 12px;font-size:.81rem;margin-bottom:14px;text-align:left}

/* ── APP ────────────────────────────────────────────────── */
#app{display:none;max-width:980px;margin:0 auto;padding:20px 16px}
header{background:#5B36A9;color:#fff;border-radius:12px;padding:13px 18px;display:flex;align-items:center;justify-content:space-between;margin-bottom:13px;flex-wrap:wrap;gap:8px}
header h1{font-size:1.05rem;font-weight:700}
.header-right{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.user-badge{background:rgba(255,255,255,.2);border-radius:20px;padding:4px 12px;font-size:.81rem}
.btn-hdr{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#fff;padding:5px 11px;border-radius:6px;cursor:pointer;font-size:.77rem;transition:.15s}
.btn-hdr:hover{background:rgba(255,255,255,.27)}

/* ── ALERT ──────────────────────────────────────────────── */
#alertBanner{display:none;background:#fff3cd;border:1px solid #ffc107;border-radius:9px;padding:9px 14px;margin-bottom:11px;font-size:.82rem;color:#856404;line-height:1.5}

/* ── TABS ───────────────────────────────────────────────── */
.tabs{display:flex;gap:5px;margin-bottom:13px;flex-wrap:wrap}
.tab{padding:7px 13px;border-radius:8px;cursor:pointer;font-size:.83rem;font-weight:600;border:2px solid transparent;background:#fff;color:#5B36A9;transition:.2s;white-space:nowrap}
.tab.active{background:#5B36A9;color:#fff}
.tab:hover:not(.active){border-color:#5B36A9}
.tab.t-admin{color:#e76f51}
.tab.t-admin.active{background:#e76f51;color:#fff}
.tab.t-admin:hover:not(.active){border-color:#e76f51}

/* ── PANELS ─────────────────────────────────────────────── */
.panel{display:none}.panel.active{display:block}
.card{background:#fff;border-radius:12px;padding:17px 19px;margin-bottom:13px;box-shadow:0 2px 10px rgba(91,54,169,.07)}
.card h2{font-size:.93rem;color:#5B36A9;margin-bottom:11px;font-weight:700}
.card.a h2{color:#e76f51}

/* ── FORMS ──────────────────────────────────────────────── */
.q-row{display:flex;gap:13px}
@media(max-width:580px){.q-row{flex-direction:column}}
.q-box{flex:1;background:#f5f3fb;border-radius:10px;padding:13px}
.q-box h3{font-size:.78rem;color:#5B36A9;font-weight:700;margin-bottom:9px;text-transform:uppercase;letter-spacing:.04em}
.frow{display:flex;gap:9px;margin-bottom:9px;align-items:flex-end;flex-wrap:wrap}
.fg{display:flex;flex-direction:column;gap:3px;flex:1;min-width:90px}
.fg label{font-size:.74rem;color:#666;font-weight:600}
.fg input,.fg select{padding:7px 10px;border-radius:7px;border:1.5px solid #e0daf0;font-size:.87rem;outline:none;background:#fff;color:#1a1a2e}
.fg input:focus,.fg select:focus{border-color:#5B36A9}
.ibox{background:#ede9f9;border-radius:7px;padding:8px 11px;font-size:.8rem;color:#5B36A9;margin-bottom:11px}
.btn-p{background:#5B36A9;color:#fff;border:none;padding:8px 17px;border-radius:8px;cursor:pointer;font-weight:600;font-size:.86rem;transition:.15s}
.btn-p:hover{background:#4a2d8e}
.btn-s{background:#f5f3fb;color:#5B36A9;border:2px solid #5B36A9;padding:6px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:.82rem}
.btn-s:hover{background:#ede9f9}
.btn-d{background:#fff0f0;color:#c0392b;border:1.5px solid #f5c6cb;padding:6px 13px;border-radius:8px;cursor:pointer;font-weight:600;font-size:.82rem}
.btn-d:hover{background:#f8d7da}
.btn-a{background:#e76f51;color:#fff;border:none;padding:7px 16px;border-radius:8px;cursor:pointer;font-weight:600;font-size:.86rem}
.btn-a:hover{background:#c9573b}
.msg{padding:7px 12px;border-radius:7px;font-size:.82rem;margin-top:7px;display:none}
.msg.ok{background:#d4edda;color:#155724;display:block}
.msg.err{background:#f8d7da;color:#721c24;display:block}

/* ── TABLES ─────────────────────────────────────────────── */
table{width:100%;border-collapse:collapse;font-size:.84rem}
th{background:#5B36A9;color:#fff;padding:7px 10px;text-align:left;font-weight:600}
td{padding:7px 10px;border-bottom:1px solid #f0edf8}
tr:last-child td{border-bottom:none}
tr:hover td{background:#f9f7fe}
.bk{display:inline-block;padding:2px 8px;border-radius:12px;font-size:.74rem;font-weight:700}
.bk-g{background:#d4edda;color:#155724}
.bk-p{background:#ede9f9;color:#5B36A9}
.bk-o{background:#fff3cd;color:#856404}
.bk-r{background:#f8d7da;color:#721c24}

/* ── FERIE ──────────────────────────────────────────────── */
.fi{display:flex;align-items:flex-start;justify-content:space-between;padding:9px 12px;background:#f5f3fb;border-radius:8px;margin-bottom:6px;font-size:.84rem;gap:8px}
.fi .meta{color:#888;font-size:.76rem;margin-top:2px}
.btn-del{background:none;border:none;color:#dc3545;cursor:pointer;font-size:.95rem;padding:2px 4px;flex-shrink:0}
.srow{display:flex;gap:7px;margin-bottom:10px;flex-wrap:wrap}
.srow input,.srow select{padding:7px 10px;border-radius:7px;border:1.5px solid #e0daf0;font-size:.83rem;outline:none}
.srow input:focus,.srow select:focus{border-color:#5B36A9}
.ow{background:#fff3cd;border:1px solid #ffc107;border-radius:7px;padding:7px 11px;font-size:.8rem;color:#856404;margin-top:5px;display:none}

/* ── TREND ──────────────────────────────────────────────── */
.tleg{display:flex;gap:14px;flex-wrap:wrap;font-size:.79rem;margin-top:9px}
.tdot{width:11px;height:11px;border-radius:50%;flex-shrink:0;display:inline-block;vertical-align:middle;margin-right:4px}

/* ── OVERVIEW ───────────────────────────────────────────── */
.ov-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
.ov-cards{display:flex;gap:11px;flex-wrap:wrap;margin-bottom:13px}
.ov-card{flex:1;min-width:140px;background:#f5f3fb;border-radius:10px;padding:11px 13px;border:1.5px solid #e0daf0}
.ov-card .on{font-weight:700;font-size:.82rem;margin-bottom:2px}
.ov-card .od{font-size:1.45rem;font-weight:700;color:#1a1a2e;line-height:1.1}
.ov-card .oi{font-size:.73rem;color:#888;margin-top:2px}

/* ── ADMIN risorse ──────────────────────────────────────── */
.rrow{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;background:#f5f3fb;border-radius:8px;margin-bottom:6px;gap:8px}
.rrow .rn{font-weight:700;font-size:.88rem}
.rrow .rl{font-size:.76rem;color:#888;margin-top:1px}
.rrow .ra{display:flex;gap:6px;align-items:center;flex-shrink:0}
.pwd-status{font-size:.74rem;padding:2px 7px;border-radius:10px;font-weight:700}
.pwd-set{background:#d4edda;color:#155724}
.pwd-unset{background:#fff3cd;color:#856404}

/* ── MODAL ──────────────────────────────────────────────── */
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;padding:16px}
.mo.open{display:flex}
.mb{background:#fff;border-radius:14px;padding:24px 24px 18px;max-width:400px;width:100%;box-shadow:0 10px 50px rgba(0,0,0,.2)}
.mb h3{font-size:.97rem;margin-bottom:7px;font-weight:700}
.mb p{font-size:.86rem;color:#555;margin-bottom:17px;line-height:1.5}
.ma{display:flex;gap:9px;justify-content:flex-end}

/* ── REPERIBILITÀ ───────────────────────────────────────── */
.tab.t-lead{color:#1d7fc4}
.tab.t-lead.active{background:#1d7fc4;color:#fff}
.tab.t-lead:hover:not(.active){border-color:#1d7fc4}
.card.lead h2{color:#1d7fc4}
.btn-lead{background:#1d7fc4;color:#fff;border:none;padding:8px 17px;border-radius:8px;cursor:pointer;font-weight:600;font-size:.86rem;transition:.15s}
.btn-lead:hover{background:#1565a8}
.rep-griglia{overflow-x:auto;margin-top:11px}
.rep-griglia table{border-collapse:collapse;font-size:.75rem;min-width:100%}
.rep-griglia th{background:#1d7fc4;color:#fff;padding:5px 4px;text-align:center;min-width:26px;white-space:nowrap}
.rep-griglia th.th-name{text-align:left;min-width:110px;padding:5px 9px}
.rep-griglia td{padding:3px 2px;text-align:center;border:1px solid #e8f0f8}
.rep-griglia td.td-name{text-align:left;padding:5px 9px;font-weight:600;font-size:.8rem;border:1px solid #e0daf0;background:#f5f8ff;white-space:nowrap}
.rep-day{width:18px;height:18px;border-radius:4px;border:2px solid #c8def0;background:#fff;cursor:pointer;display:inline-block;transition:.1s}
.rep-day.on{background:#1d7fc4;border-color:#1d7fc4}
.rep-day.weekend{background:#f5f3fb;border-color:#e0daf0;cursor:default}
.rep-day.festivo{background:#ede9f9;border-color:#c8b8f0;cursor:default}
.rep-entry{display:flex;align-items:flex-start;justify-content:space-between;padding:10px 13px;background:#f0f7ff;border-radius:8px;margin-bottom:7px;gap:8px;border:1px solid #c8def0}
.rep-entry .re-prog{font-weight:700;color:#1d7fc4;font-size:.88rem}
.rep-entry .re-meta{font-size:.76rem;color:#888;margin-top:2px}
.rep-entry .re-days{font-size:.75rem;margin-top:4px;color:#555;line-height:1.6}
.acc-hdr{display:flex;align-items:center;justify-content:space-between;padding:2px 0}
.acc-hdr h2{margin-bottom:0}
.acc-toggle{background:#e76f51;color:#fff;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;flex-shrink:0;font-weight:700;font-size:.8rem;transition:.15s}
.acc-toggle:hover{background:#c9573b}
.prj-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px;min-height:0}
.prj-tag{display:inline-flex;align-items:center;gap:4px;background:#ede9f9;color:#5B36A9;border-radius:12px;padding:3px 10px;font-size:.78rem;font-weight:600}
.prj-tag button{background:none;border:none;color:#5B36A9;cursor:pointer;font-size:.85rem;line-height:1;padding:0 0 0 2px}
.prj-tag button:hover{color:#c0392b}
.acc-body{display:none}
.acc-body.open{display:block}
</style>
</head>
<body>
<div id="netSpinner" style="display:none;position:fixed;inset:0;background:rgba(91,54,169,.12);z-index:9999;align-items:center;justify-content:center">
  <div style="width:40px;height:40px;border:4px solid #ede9f9;border-top-color:#5B36A9;border-radius:50%;animation:spin .7s linear infinite"></div>
</div>
<style>@keyframes spin{to{transform:rotate(360deg)}}</style>


<!-- MODAL -->
<div class="mo" id="MO">
  <div class="mb">
    <h3 id="MT"></h3><p id="MM"></p>
    <div class="ma">
      <button class="btn-s" onclick="MC()">Annulla</button>
      <button class="btn-d" id="MK">Conferma</button>
    </div>
  </div>
</div>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-box">
    <h1>⏱ Team Hours Tracker</h1>
    <p class="subtitle" id="loginSub">Seleziona il tuo nome per accedere</p>

    <!-- step 1: scelta nome / admin -->
    <div id="stepSelect">
      <select id="loginSel"><option value="">— Seleziona il tuo nome —</option></select>
      <div class="login-err" id="errSel">Seleziona un nome dalla lista.</div>
      <button class="btn-login purple" onclick="goStepPwd()">Continua →</button>
      <br>
      <button class="btn-link" onclick="goAdminLogin()">Accesso admin</button>
    </div>

    <!-- step 2a: primo accesso → imposta password -->
    <div id="stepFirstAccess" style="display:none">
      <div class="first-access-badge">👋 Primo accesso — imposta la tua password</div>
      <input type="password" id="pwd1stA" placeholder="Scegli una password (min. 6 caratteri)"/>
      <input type="password" id="pwd1stB" placeholder="Conferma password"/>
      <div class="login-err" id="err1st"></div>
      <button class="btn-login purple" onclick="doFirstAccess()">Imposta password e accedi</button>
      <button class="btn-link" onclick="goStepSelect()">← Indietro</button>
    </div>

    <!-- step 2b: accesso normale -->
    <div id="stepPwd" style="display:none">
      <div id="loginWhoLabel" style="font-size:.85rem;color:#888;margin-bottom:10px"></div>
      <input type="password" id="pwdInput" placeholder="Password" onkeydown="if(event.key==='Enter')doUserLogin()"/>
      <div class="login-err" id="errPwd">Password errata.</div>
      <button class="btn-login purple" onclick="doUserLogin()">Accedi</button>
      <button class="btn-link" onclick="goStepSelect()">← Indietro</button>
    </div>

    <!-- admin login -->
    <div id="stepAdmin" style="display:none">
      <input type="password" id="adminPwd" placeholder="Password admin" onkeydown="if(event.key==='Enter')doAdminLogin()"/>
      <div class="login-err" id="errAdmin">Password errata.</div>
      <button class="btn-login orange" onclick="doAdminLogin()">Accedi come Admin</button>
      <button class="btn-link" onclick="goStepSelect()">← Indietro</button>
    </div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <header>
    <h1>⏱ Team Hours Tracker</h1>
    <div class="header-right">
      <span class="user-badge" id="hUser"></span>
      <button class="btn-hdr" onclick="exportBackup()">💾 Backup</button>
      <button class="btn-hdr" onclick="document.getElementById('importFile').click()">📂 Ripristina</button>
      <input type="file" id="importFile" accept=".json" style="display:none" onchange="importBackup(event)"/>
      <button class="btn-hdr" onclick="doLogout()">Esci</button>
    </div>
  </header>

  <div id="alertBanner"></div>

  <div class="tabs" id="mainTabs">
    <div class="tab active" id="tabOre" onclick="showTab('ore')">📋 Le mie ore</div>
    <div class="tab" onclick="showTab('riepilogo')" id="tabRiepilogo">👥 Riepilogo team</div>
    <div class="tab" onclick="showTab('trend')" id="tabTrend">📈 Trend</div>
    <div class="tab" onclick="showTab('ferie')">🌴 Ferie</div>
    <div class="tab" id="tabOverview" onclick="showTab('overview')">📅 Overview</div>
    <div class="tab t-lead" id="tabRep" style="display:none" onclick="showTab('reperibilita')">📡 Reperibilità</div>
    <div class="tab t-admin" id="tabAdmin" style="display:none" onclick="showTab('admin')">⚙️ Admin</div>
  </div>

  <!-- LE MIE ORE -->
  <div class="panel active" id="panel-ore">
    <div class="card">
      <h2>Inserimento ore mensili</h2>
      <div class="frow">
        <div class="fg" style="max-width:175px"><label>Mese</label><select id="oreMonth"></select></div>
        <div class="fg" style="max-width:105px"><label>Anno</label><select id="oreYear"></select></div>
        <div style="padding-bottom:2px"><button class="btn-s" onclick="loadOreForm()">Carica</button></div>
      </div>
      <div id="oreInfoBox" class="ibox" style="display:none"></div>
      <div class="q-row">
        <div class="q-box">
          <h3>I Quindicina (1–15)</h3>
          <div class="fg"><label>Ore lavorate</label><input type="number" id="ore1" min="0" max="300" step="0.5"/></div>
          <div class="fg" style="margin-top:8px"><label>Note (opzionale)</label><input type="text" id="note1" placeholder="Note..."/></div>
        </div>
        <div class="q-box">
          <h3>II Quindicina (16–fine mese)</h3>
          <div class="fg"><label>Ore lavorate</label><input type="number" id="ore2" min="0" max="300" step="0.5"/></div>
          <div class="fg" style="margin-top:8px"><label>Note (opzionale)</label><input type="text" id="note2" placeholder="Note..."/></div>
        </div>
      </div>
      <div style="margin-top:12px;display:flex;gap:9px;align-items:center;flex-wrap:wrap">
        <button class="btn-p" onclick="saveOre()">💾 Salva ore</button>
        <div id="oreMsg" class="msg"></div>
      </div>
    </div>
    <div class="card">
      <h2>Le mie ore inserite</h2>
      <div id="myOreList"><p style="color:#888;font-size:.84rem">Nessuna ora inserita.</p></div>
    </div>
  </div>

  <!-- RIEPILOGO (solo admin) -->
  <div class="panel" id="panel-riepilogo">
    <div class="card">
      <h2>Riepilogo team</h2>
      <div class="frow">
        <div class="fg" style="max-width:175px"><label>Mese</label><select id="riepilogoMonth"></select></div>
        <div class="fg" style="max-width:105px"><label>Anno</label><select id="riepilogoYear"></select></div>
        <div class="fg" style="max-width:190px"><label>Team Lead</label><select id="riepilogoLead" onchange="loadRiepilogo()"><option value="">Tutti</option></select></div>
        <div style="padding-bottom:2px"><button class="btn-s" onclick="loadRiepilogo()">Aggiorna</button></div>
      </div>
      <div id="riepilogoTable"></div>
      <div style="margin-top:11px"><button class="btn-p" onclick="exportExcel()">📥 Esporta Excel</button></div>
    </div>
  </div>

  <!-- TREND (solo admin) -->
  <div class="panel" id="panel-trend">
    <div class="card">
      <h2>Trend ore — ultimi mesi</h2>
      <div class="frow" style="margin-bottom:13px">
        <div class="fg" style="max-width:150px"><label>Mesi</label>
          <select id="trendMonths" onchange="renderTrend()">
            <option value="6">6 mesi</option><option value="9">9 mesi</option><option value="12" selected>12 mesi</option>
          </select>
        </div>
        <div class="fg" style="max-width:190px"><label>Team Lead</label><select id="trendLead" onchange="renderTrend()"><option value="">Tutti</option></select></div>
      </div>
      <canvas id="trendCanvas" height="250"></canvas>
      <div class="tleg" id="trendLegend"></div>
    </div>
    <div class="card"><h2>Avvisi</h2><div id="trendAlerts"></div></div>
  </div>

  <!-- FERIE (tutti) -->
  <div class="panel" id="panel-ferie">
    <div class="card">
      <h2>Inserisci ferie / permessi</h2>
      <div class="frow">
        <div class="fg"><label>Data inizio</label><input type="date" id="ferieStart" onchange="checkOverlap()"/></div>
        <div class="fg"><label>Data fine</label><input type="date" id="ferieEnd" onchange="checkOverlap()"/></div>
        <div class="fg" style="max-width:125px"><label>Tipo</label>
          <select id="ferieTipo"><option>Ferie</option><option>Permesso</option><option>ROL</option><option>Malattia</option></select>
        </div>
        <div class="fg"><label>Note (opzionale)</label><input type="text" id="ferieNote" placeholder="Note..."/></div>
        <div style="padding-bottom:2px"><button class="btn-p" onclick="saveFerie()">➕ Aggiungi</button></div>
      </div>
      <div id="overlapWarn" class="ow"></div>
      <div id="ferieMsg" class="msg"></div>
      <button class="btn-s" style="margin-top:9px" onclick="exportICS()">📆 Esporta .ics</button>
    </div>

    <!-- Selettore risorse (solo utenti normali) -->
    <div class="card" id="ferieRisorseCard" style="display:none">
      <h2>👥 Scegli chi vuoi monitorare</h2>
      <p style="font-size:.82rem;color:#888;margin-bottom:11px">Seleziona le risorse di cui vuoi vedere le ferie (le tue sono sempre incluse).</p>
      <div id="ferieRisorseCheck" style="display:flex;flex-wrap:wrap;gap:8px 16px;margin-bottom:11px"></div>
      <div style="display:flex;gap:8px">
        <button class="btn-s" onclick="selAllFerieRisorse(true)">Seleziona tutti</button>
        <button class="btn-s" onclick="selAllFerieRisorse(false)">Deseleziona tutti</button>
      </div>
    </div>

    <div class="card">
      <h2>Ferie del team</h2>
      <div class="srow">
        <input type="text" id="searchFerie" placeholder="Cerca nome, note..." oninput="renderFerieList()" style="flex:1;min-width:110px"/>
