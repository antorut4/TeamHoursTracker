function fmt(ds){ const[y,m,d]=ds.split('-'); return `${d}/${m}/${y}`; }
function showMsg(id,txt,t){ const el=document.getElementById(id); if(!el)return; el.textContent=txt; el.className='msg '+t; setTimeout(()=>{el.className='msg';},3500); }
function popSel(id,opts,sel){
  const s=document.getElementById(id); if(!s)return; s.innerHTML='';
  opts.forEach(({v,l})=>{ const o=document.createElement('option'); o.value=v; o.textContent=l; if(String(v)===String(sel))o.selected=true; s.appendChild(o); });
}
let _mcb=null;
function openModal(title,msg,cb,lbl){
