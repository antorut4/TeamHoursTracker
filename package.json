  if(!staffed.length){el.innerHTML='<p style="color:#888;font-size:.84rem">Nessuna risorsa allocata su questo progetto.</p>';return;}
  el.innerHTML=`<div style="font-size:.78rem;color:#e76f51;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">${staffed.length} risorsa${staffed.length!==1?'e':''} su ${prj}</div>`+
    staffed.map(r=>`
    <div class="rrow">
      <div>
        <div class="rn">${r.fullName}</div>
