async function importBackup(event){
  // Con il database condiviso il ripristino da file è disabilitato: sovrascriverebbe
  // i dati di tutto il team. Il restore si fa dagli snapshot / PITR della console Neon.
  if(event && event.target) event.target.value='';
  alert('Ripristino da file disabilitato.\n\nI dati sono condivisi sul database: un import sovrascriverebbe il lavoro di tutto il team. Per tornare a uno stato precedente usa gli snapshot / Point-in-Time Restore dalla console Neon.\n\nL\u0027export resta attivo per tenere una copia dei dati.');
}

