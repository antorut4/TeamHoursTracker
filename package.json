// INIT
// ═══════════════════════════════════════════════════════════
async function initApp(){
  const now=new Date();
  const mOpts=MONTHS.map((m,i)=>({v:i,l:m}));
  const yOpts=[-1,0,1].map(d=>{ const y=now.getFullYear()+d; return {v:y,l:y}; });
  ['oreMonth','riepilogoMonth','ovMonth'].forEach(id=>popSel(id,mOpts,now.getMonth()));
  ['oreYear','riepilogoYear','ovYear'].forEach(id=>popSel(id,yOpts,now.getFullYear()));
  const yOptsFerie=[{v:'',l:'Tutti gli anni'},...yOpts];
  popSel('filterAnno',yOptsFerie,'');
  refreshDropdowns();
  if(!isAdmin){ await loadOreForm(); await renderMyOre(); checkAlerts(); initFerieRisorseCard(); }
  await renderFerieList();
  await populateProgettoSelect('res', getProgettoSelected('res'));
  await populateProgettoSelect('edit', getProgettoSelected('edit'));
  if(isAdmin){ await renderResourceList(); await renderProjectList(); await populateSearchByProject(); }
}

function refreshDropdowns(){
  const leads=getLeads();
  const lOpts=[{v:'',l:'Tutti'},...leads.map(l=>({v:l,l:l}))];
  ['riepilogoLead','trendLead','ovLead','filterResLead'].forEach(id=>popSel(id,lOpts,''));
  const mOpts=[{v:'',l:'Tutti'},...RESOURCES.map(r=>({v:r.fullName,l:r.fullName}))];
  popSel('filterMembro',mOpts,'');
  // datalist team lead
  const dl=document.getElementById('ldSug');
  if(dl){ dl.innerHTML=''; leads.forEach(l=>{ const o=document.createElement('option'); o.value=l; dl.appendChild(o); }); }
  // login select
  const sl=document.getElementById('loginSel');
  sl.innerHTML='<option value="">— Seleziona il tuo nome —</option>';
  RESOURCES.forEach(r=>{ const o=document.createElement('option'); o.value=r.fullName; o.textContent=r.fullName; sl.appendChild(o); });
}

// ═══════════════════════════════════════════════════════════
// ALERT BANNER
// ═══════════════════════════════════════════════════════════
async function checkAlerts(){
  if(isAdmin||!RESOURCES.length) return;
  const r=RESOURCES.find(x=>x.fullName===currentUser); if(!r)return;
  const now=new Date(), missing=[];
  const limit=now.getDate()<=5?1:0;
  const checks=[];
  for(let back=limit+1;back<=limit+3;back++){
    let m=now.getMonth()-back, y=now.getFullYear();
    if(m<0){m+=12;y--;} checks.push({m,y,label:MONTHS[m]+' '+y});
  }
  const recs=(_read(K_HRS, [])||[]).filter(o=>o.risorsaId===r.id);
  const inserted=new Set(recs.map(x=>`${x.anno}||${x.mese}`));
  checks.forEach(({m,y,label})=>{ if(!inserted.has(`${y}||${m}`)) missing.push(label); });
  const b=document.getElementById('alertBanner');
  if(missing.length){ b.style.display='block'; b.innerHTML=`⚠️ <b>Ore mancanti:</b> ${missing.join(', ')}`; }
  else b.style.display='none';
}

