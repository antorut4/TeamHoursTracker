    </div>`).join('');
}

async function addResource(){
  const nome=document.getElementById('resNome').value.trim(), cognome=document.getElementById('resCognome').value.trim(), lead=document.getElementById('resLead').value.trim();
  const progetti=getProgettoSelected('res');
  if(!nome||!cognome){showMsg('addResMsg','Nome e Cognome sono obbligatori.','err');return;}
  if(!progetti.length){showMsg('addResMsg','Seleziona almeno un progetto.','err');return;}
  const fn=nome+' '+cognome;
  if(RESOURCES.find(r=>r.fullName.toLowerCase()===fn.toLowerCase())){showMsg('addResMsg','Risorsa già presente.','err');return;}
  showSpinner();
  try {
    await call('addResource', { nome, cognome, teamLead:lead||null, progetti });
    await reloadAll();
  } catch(e){ hideSpinner(); showMsg('addResMsg','Errore: '+e.message,'err'); return; }
  hideSpinner();
  document.getElementById('resNome').value=''; document.getElementById('resCognome').value=''; document.getElementById('resLead').value=''; populateProgettoSelect('res',[]);
  await renderResourceList(); refreshDropdowns(); checkAlerts();
  showMsg('addResMsg',`${fn} aggiunto/a ✓`,'ok');
}
async function renderResourceList(){
  const search=(document.getElementById('searchRes')?.value||'').toLowerCase();
  const lf=document.getElementById('filterResLead')?.value||'';
  // aggiorna datalist e filtro
  const leads=getLeads();
  const fl=document.getElementById('filterResLead');
  if(fl){ const pv=fl.value; fl.innerHTML='<option value="">Tutti i team lead</option>'; leads.forEach(l=>{const o=document.createElement('option');o.value=l;o.textContent=l;if(l===pv)o.selected=true;fl.appendChild(o);}); }
  const el=document.getElementById('resourceList'); if(!el)return;
  if(!RESOURCES.length){el.innerHTML='<p style="color:#888;font-size:.84rem">Nessuna risorsa ancora.</p>';return;}
  let filtered=RESOURCES.filter(r=>{ if(lf&&r.teamLead!==lf)return false; if(search&&!r.fullName.toLowerCase().includes(search)&&!r.teamLead.toLowerCase().includes(search))return false; return true; });
  if(!filtered.length){el.innerHTML='<p style="color:#aaa;font-size:.84rem">Nessun risultato.</p>';return;}
  // stato password: una RPC per risorsa (gli hash non sono leggibili dall'endpoint)
  const pwds={};
  try {
    const res=await Promise.all(filtered.map(r=>call('userHasPwd',{risorsaId:r.id})));
    filtered.forEach((r,i)=>{ pwds[r.id]=!!res[i]; });
  } catch(e){ console.error('stato password', e); }
  const grouped={};
  filtered.forEach(r=>{ const k=r.teamLead||'Senza team lead'; if(!grouped[k])grouped[k]=[]; grouped[k].push(r); });
  let h='';
  Object.entries(grouped).sort().forEach(([lead,mems])=>{
    h+=`<div style="font-size:.74rem;color:#e76f51;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin:13px 0 5px;padding-bottom:3px;border-bottom:1px solid #fcd5c8">${lead} <span style="font-weight:400;color:#ddd">(${mems.length})</span></div>`;
    mems.forEach(r=>{
      const idx=RESOURCES.indexOf(r), hasPwd=!!pwds[r.id];
      h+=`<div class="rrow">
        <div>
          <div class="rn">${r.fullName}</div>
          <div class="rl">Team Lead: ${r.teamLead||'—'} &nbsp;·&nbsp; 📁 ${(r.progetti||[r.progetto]).filter(Boolean).join(', ')||'—'} &nbsp;·&nbsp; <span class="pwd-status ${hasPwd?'pwd-set':'pwd-unset'}">${hasPwd?'🔐 Password impostata':'⚠️ Nessuna password'}</span></div>
        </div>
        <div class="ra">
          ${!hasPwd?'':`<button class="btn-d" style="font-size:.75rem;padding:4px 9px" onclick="confirmResetPwd(${idx},'${r.fullName.replace(/'/g,"\\'")}')">Reset pwd</button>`}
          <button class="btn-s" style="font-size:.75rem;padding:4px 9px" onclick="startEdit(${idx})">✏️</button>
          <button class="btn-del" onclick="deleteResource(${idx},'${r.fullName.replace(/'/g,"\\'")}')">🗑</button>
        </div>
      </div>`;
    });
  });
  h+=`<div style="color:#ccc;font-size:.77rem;margin-top:11px">Totale: ${RESOURCES.length} risorsa${RESOURCES.length!==1?'e':''}</div>`;
  el.innerHTML=h;
}
async function confirmResetPwd(idx,name){
  openModal('Reset password',`Resettare la password di "${name}"? Al prossimo accesso dovrà impostarne una nuova.`,async ()=>{
    await resetUserPwd(name); await renderResourceList(); showMsg('resourceMsg',`Password di ${name} resettata.`,'ok');
  },'Reset');
}
